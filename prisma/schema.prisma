// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Hero Section
model Hero {
  id          Int      @id @default(autoincrement())
  intro       String
  name        String
  description String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  roles       Role[]
}

model Role {
  id     Int    @id @default(autoincrement())
  text   String
  order  Int    @default(0)
  heroId Int
  hero   Hero   @relation(fields: [heroId], references: [id], onDelete: Cascade)
}

// About Section
model About {
  id        Int      @id @default(autoincrement())
  text      String   @db.Text
  image     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Experience
model Experience {
  id          Int      @id @default(autoincrement())
  period      String
  institution String
  position    String
  description String   @db.Text
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Projects
model FeaturedProject {
  id           Int      @id @default(autoincrement())
  label        String
  title        String
  description  String   @db.Text
  technologies String[] // Array of strings
  github       String
  demo         String?
  image        String
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model OtherProject {
  id           Int      @id @default(autoincrement())
  title        String
  description  String   @db.Text
  technologies String[] // Array of strings
  github       String
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Contact
model Contact {
  id        Int      @id @default(autoincrement())
  text      String   @db.Text
  email     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Social Media
model Social {
  id        Int      @id @default(autoincrement())
  github    String
  linkedin  String
  email     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Settings
model Settings {
  id          Int      @id @default(autoincrement())
  cvUrl       String
  accentColor String   @default("#64ffda")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
